{
  "name": "ffuf_scan",
  "display_name": "FFUF Directory & File Fuzzer",
  "version": "1.0.0",
  "description": "Fuzzes a web target for hidden directories, files, and endpoints using ffuf. This sends a high volume of automated requests to the target — it can trip WAFs, rate limits, or alerting, so treat it as active recon rather than a passive scan.",
  "job_types": [
    {
      "type": "ffuf_scan",
      "label": "FFUF Fuzzing",
      "agent_capability": "ffuf_scan",
      "risk_tier": "intrusive",
      "tab": "loki",
      "section": "web",
      "form_fields": [
        { "name": "target", "type": "text", "required": true, "label": "Target URL" },
        { "name": "wordlist_path", "type": "text", "required": true, "label": "Wordlist path (on the scanner)", "default": "/usr/share/wordlists/dirb/common.txt" },
        { "name": "extensions", "type": "text", "required": false, "label": "Extensions, comma-separated (optional)" },
        { "name": "match_codes", "type": "text", "required": false, "label": "Match status codes", "default": "200,204,301,302,307,401,403" },
        { "name": "threads", "type": "number", "required": false, "label": "Threads", "default": 40 }
      ],
      "result_display": {
        "summary_fields": ["target", "total_hits"],
        "sections": [
          { "key": "hits", "label": "Fuzzing Hits", "type": "table", "columns": ["url", "status", "length"] }
        ]
      }
    }
  ],
  "hooks": []
}
